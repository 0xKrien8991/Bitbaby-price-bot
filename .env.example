# ───────────────────────────────────────────
# BitBaby Price Bot Configuration
# ───────────────────────────────────────────

# Telegram Bot Token (从 @BotFather 获取)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# 交易跳转链接 / Trade redirect URL
TRADE_URL=https://www.bitbaby.com/en-us

# 交易链接模式 / Trade URL mode:
#   "direct" = 直接跳转到 TRADE_URL（默认）
#   "pair"   = 拼接交易对, 如 TRADE_URL/trade/BTC_USDT
TRADE_URL_MODE=direct

# 默认语言 / Default language: en or zh
DEFAULT_LANG=en
