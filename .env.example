# ───────────────────────────────────────────
# BitBaby Price Bot Configuration
# ───────────────────────────────────────────

# Telegram Bot Token (从 @BotFather 获取)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# 管理员 Telegram 用户 ID（多个用逗号分隔）
# 获取方式：Telegram 搜索 @userinfobot，发送任意消息即可看到你的 ID
ADMIN_IDS=123456789

# 默认语言 / Default language: en or zh
DEFAULT_LANG=en

# Upstash Redis（免费注册 https://upstash.com）
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here
